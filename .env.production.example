# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env.production and fill in your actual values
# ============================================================================

# ============================================================================
# TELEGRAM BOT
# ============================================================================
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_PROXY=  # Optional: proxy URL for Telegram API
TELEGRAM_CHAT_ID=your_group_chat_id  # For notifications

# ============================================================================
# API SERVER
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
API_TITLE="Crypto Jobs API"
API_VERSION=1.0.0

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=sqlite:///./crypto_jobs_prod.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/crypto_jobs

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/crypto-jobs/app.log

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# FRONTEND (NEXT.JS)
# ============================================================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# ============================================================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================
SENTRY_DSN=  # Optional: for error tracking
MIXPANEL_TOKEN=  # Optional: for analytics
DATADOG_API_KEY=  # Optional: for monitoring

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_NOTIFICATIONS=true
ENABLE_SCRAPER=true
ENABLE_API=true
SCRAPE_INTERVAL_HOURS=4

# ============================================================================
# REDIS CACHE (Optional, for better performance)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ============================================================================
# TIMEZONE
# ============================================================================
TZ=UTC
